{
	"name": "altium-diff-studio",
	"productName": "Altium Diff Studio",
	"description": "Local review workspace for Altium PCB, schematic and BOM differences.",
	"author": "Thomas-Lallier",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"main": "out/main/main.cjs",
	"scripts": {
		"dev": "node scripts/RunElectronVite.mjs dev",
		"build": "node scripts/RunElectronVite.mjs build",
		"pack:win": "npm run build && electron-builder --win --dir",
		"dist:win": "npm run build && electron-builder --win nsis",
		"test:installer": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/Test-WindowsInstaller.ps1",
		"preview": "node scripts/RunElectronVite.mjs preview",
		"check": "svelte-check --config ./svelte.config.js --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --config ./svelte.config.js --tsconfig ./tsconfig.json --watch",
		"test": "node --experimental-strip-types --test tests/*.test.ts",
		"test:performance": "node --experimental-strip-types benchmarks/pcbPerformance.ts",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/node": "^24",
		"electron": "^38.0.0",
		"electron-builder": "^26.15.3",
		"electron-vite": "^4.0.0",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^7.2.7"
	},
	"build": {
		"appId": "io.github.altium-diff-studio",
		"productName": "Altium Diff Studio",
		"asar": true,
		"directories": {
			"output": "release",
			"buildResources": "build"
		},
		"files": [
			"out/**/*",
			"package.json"
		],
		"win": {
			"icon": "build/icon.ico",
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64"
					]
				}
			],
			"artifactName": "${productName}-Setup-${version}-unsigned.${ext}"
		},
		"nsis": {
			"oneClick": false,
			"perMachine": false,
			"allowToChangeInstallationDirectory": true,
			"createDesktopShortcut": true,
			"createStartMenuShortcut": true,
			"shortcutName": "Altium Diff Studio",
			"uninstallDisplayName": "Altium Diff Studio ${version} (unsigned)"
		}
	},
	"dependencies": {
		"pdfjs-dist": "^6.1.200"
	}
}
